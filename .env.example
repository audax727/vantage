# Copy this file to ".env" and fill in what you have.
# Every value below is OPTIONAL except FLASK_SECRET_KEY (recommended).
# Vantage runs fully in mock mode with no keys set at all.

# --- Core security ---
# A random secret used to sign session cookies. Generate one with:
#   python -c "import secrets; print(secrets.token_hex(32))"
FLASK_SECRET_KEY=

# --- Google Sign-In (optional) ---
# From https://console.cloud.google.com/apis/credentials
# Authorized redirect URI to add there: http://localhost:5000/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- AI product chat widget (optional) ---
# From https://console.anthropic.com/settings/keys
# Without this, the storefront chat falls back to simple keyword matching.
ANTHROPIC_API_KEY=

# --- Email notifications via Gmail SMTP (optional) ---
# EMAIL_ADDRESS: the Gmail address notifications are sent FROM
# EMAIL_APP_PASSWORD: a 16-character App Password (NOT your regular Gmail password)
#   Generate one at https://myaccount.google.com/apppasswords
#   (requires 2-Step Verification to be enabled on the Google account)
# Without these, notifications are logged in mock mode and still show in the UI.
EMAIL_ADDRESS=
EMAIL_APP_PASSWORD=

# --- Database (optional) ---
DB_PATH=vantage.db
